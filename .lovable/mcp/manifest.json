{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "velaro-mcp",
      "version": "0.1.0",
      "title": "VELARO MCP"
    },
    "tools": [
      {
        "name": "list_collection",
        "title": "List VELARO collection",
        "description": "Return the current VELARO luxury eyewear collection with prices and materials.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_product",
        "title": "Get VELARO product",
        "description": "Fetch detailed information for a single VELARO product by its ID.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "Product ID, e.g. 'velaro-noir', 'velaro-titan', 'velaro-gold'."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
